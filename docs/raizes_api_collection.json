    {
      "name": "Auth",
      "item": [
        {
          "name": "[Auth] T01 Login CLIENTE (salva token)",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Retorna accessToken', () => {",
            "  const j = pm.response.json();",
            "  pm.expect(j.accessToken).to.be.a('string');",
            "  pm.collectionVariables.set('token_cliente', j.accessToken);",
            "});",
            "pm.test('Perfil = CLIENTE', () => pm.expect(pm.response.json().user.perfil).to.eql('CLIENTE'));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "options": {"raw": {"language": "json"}}, "raw": "{\"email\": \"cliente@teste.com\", \"senha\": \"Teste@123\"}"},
            "url": {"raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"]}
          }
        },
        {
          "name": "[Auth] Login ADMIN (salva token)",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",

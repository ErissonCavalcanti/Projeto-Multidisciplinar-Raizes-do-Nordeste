    {
      "name": "Pedidos",
      "item": [
        {
          "name": "[Pedidos] T04 Criar pedido APP → 201",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "pm.test('Salva pedidoId', () => {",
            "  const j = pm.response.json();",
            "  pm.expect(j.pedidoId).to.be.a('number');",
            "  pm.collectionVariables.set('pedido_id', j.pedidoId);",
            "});",
            "pm.test('canalPedido = APP', () => pm.expect(pm.response.json().canalPedido).to.eql('APP'));",
            "pm.test('status = AGUARDANDO_PAGAMENTO', () => pm.expect(pm.response.json().status).to.eql('AGUARDANDO_PAGAMENTO'));",
            "pm.test('Total > 0', () => pm.expect(pm.response.json().total).to.be.above(0));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{token_cliente}}"}],
            "body": {"mode": "raw", "options": {"raw": {"language": "json"}}, "raw": "{\"unidade_id\": {{unidade_id}}, \"canalPedido\": \"APP\", \"itens\": [{\"produto_id\": {{produto_id_com_estoque}}, \"quantidade\": 2}], \"forma_pagamento\": \"MOCK\"}"},
            "url": {"raw": "{{base_url}}/pedidos", "host": ["{{base_url}}"], "path": ["pedidos"]}
          }
        },
        {
          "name": "[Pedidos] Criar pedido TOTEM (para T11)",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",

            "pm.test('Perfil = ADMIN', () => pm.expect(pm.response.json().user.perfil).to.eql('ADMIN'));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "options": {"raw": {"language": "json"}}, "raw": "{\"email\": \"admin@email.com\", \"senha\": \"Admin@123\"}"},
            "url": {"raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"]}
          }
        },

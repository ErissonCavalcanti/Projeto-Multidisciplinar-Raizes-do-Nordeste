            "pm.test('canalPedido = TOTEM', () => pm.expect(pm.response.json().canalPedido).to.eql('TOTEM'));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{token_cliente}}"}],
            "body": {"mode": "raw", "options": {"raw": {"language": "json"}}, "raw": "{\"unidade_id\": {{unidade_id}}, \"canalPedido\": \"TOTEM\", \"itens\": [{\"produto_id\": 2, \"quantidade\": 1}], \"forma_pagamento\": \"MOCK\"}"},
            "url": {"raw": "{{base_url}}/pedidos", "host": ["{{base_url}}"], "path": ["pedidos"]}
          }
        },
        {
          "name": "[Pedidos] T07 Filtrar canalPedido=APP",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Tem paginação', () => pm.expect(pm.response.json().pagination).to.be.an('object'));",
            "pm.test('Total > 0', () => pm.expect(pm.response.json().pagination.total).to.be.above(0));",
            "pm.test('Todos canal APP', () => {",
            "  pm.response.json().data.forEach(p => pm.expect(p.canalPedido).to.eql('APP'));",
            "});"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token_admin}}"}],
            "url": {"raw": "{{base_url}}/pedidos?canalPedido=APP&page=1&limit=10", "host": ["{{base_url}}"], "path": ["pedidos"], "query": [{"key": "canalPedido", "value": "APP"}, {"key": "page", "value": "1"}, {"key": "limit", "value": "10"}]}
          }
        },
        {
          "name": "[Pedidos] Buscar pedido por ID",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('pedidoId corresponde', () => pm.expect(pm.response.json().pedidoId).to.eql(parseInt(pm.collectionVariables.get('pedido_id'))));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token_cliente}}"}],
            "url": {"raw": "{{base_url}}/pedidos/{{pedido_id}}", "host": ["{{base_url}}"], "path": ["pedidos", "{{pedido_id}}"]}
          }
        },
        {
          "name": "[Pedidos] T06 Status EM_PREPARO (após T05)",
          "event": [{"listen": "test", "script": {"type": "text/javascript", "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",

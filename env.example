# Configurações da API - Raízes do Nordeste
# Copie este ficheiro para .env e preencha os valores

# Base de dados (SQLite local para desenvolvimento)
DATABASE_URL=sqlite:///./raizes.db

# Chave secreta para assinar tokens JWT
# Gere uma chave segura com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=substitua_por_uma_chave_segura_aqui

# Algoritmo JWT (não alterar)
ALGORITHM=HS256

# Expiração do token em minutos
ACCESS_TOKEN_EXPIRE_MINUTES=60